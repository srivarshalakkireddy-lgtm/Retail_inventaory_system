# API Configuration
REACT_APP_API_URL=http://localhost:5000/api
REACT_APP_API_TIMEOUT=30000

# App Configuration
REACT_APP_NAME=Retail Inventory Management System
REACT_APP_VERSION=1.0.0

# Features
REACT_APP_ENABLE_BARCODE_SCANNER=true
REACT_APP_ENABLE_RFID=true

# Pagination
REACT_APP_DEFAULT_PAGE_SIZE=20
REACT_APP_MAX_PAGE_SIZE=100

# File Upload
REACT_APP_MAX_FILE_SIZE=5242880
REACT_APP_ALLOWED_FILE_TYPES=image/jpeg,image/png,image/jpg
